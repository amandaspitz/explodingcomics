NODE_ENV=development
PORT=3000
APP_NAME=exploding-comics-pro-api
API_BASE_PATH=/api/v1
CORS_ORIGIN=*
LOG_LEVEL=info
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=exploding_comics_pro
DB_USER=exploding_comics_app
DB_PASSWORD=change_me_local_password
DB_CONNECTION_LIMIT=10
DB_CONNECT_TIMEOUT_MS=10000
ADMIN_JWT_SECRET=change_me_with_a_long_local_secret_at_least_32_chars
ADMIN_JWT_ISSUER=exploding-comics-pro-api
ADMIN_JWT_AUDIENCE=exploding-comics-pro-admin
ADMIN_JWT_EXPIRES_IN=12h
