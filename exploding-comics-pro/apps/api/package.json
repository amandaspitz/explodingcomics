{
  "name": "exploding-comics-pro-api",
  "version": "0.1.0",
  "private": true,
  "description": "Express + MySQL API for Exploding Comics Pro",
  "main": "dist/server.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src tests --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "db:check": "tsx src/scripts/check-database.ts",
    "migrate": "tsx src/scripts/run-migrations.ts",
    "import:legacy": "tsx src/scripts/import-legacy-comics.ts",
    "create:admin-user": "tsx src/scripts/create-admin-user.ts"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "mysql2": "^3.22.5",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
